{
  "package_name": "sqli-codebert-masterfull-multiseed",
  "created_at": "2026-06-01",
  "purpose": "GitHub-ready multi-seed source-code release for the SQLi CodeBERT paper.",
  "scope": {
    "included": [
      "multi-seed proposed-model training",
      "processed MasterFull train/validation/test CSV split",
      "validation-set threshold calibration",
      "ablation/baseline/ONNX benchmark scripts needed for paper reproduction",
      "paper asset generation from real outputs"
    ],
    "excluded": [
      ".git metadata",
      "Kaggle notebooks and launchers",
      "GitHub upload guides",
      "server-local packaging scripts",
      "CSIC2010 transfer fine-tuning folder",
      "old single-run experiment entry points",
      "generated results/checkpoints/ONNX artifacts"
    ]
  },
  "default_multiseed": [
    42,
    123,
    2024
  ],
  "main_epochs": 5,
  "max_len": 256,
  "file_count": 32,
  "files": [
